# Optional: CoinGecko Demo / Pro API key. Free tier works without one.
ALPHASCANNER_COINGECKO_API_KEY=

# SQLite database location.
ALPHASCANNER_DB_PATH=/data/alphascanner.db

# Number of pages of 250 to pull (4 = top 1000 coins by market cap).
ALPHASCANNER_FETCH_PAGES=4

# Snapshot interval in minutes.
ALPHASCANNER_FETCH_INTERVAL_MINUTES=15

# Quote currency.
ALPHASCANNER_VS_CURRENCY=usd

# How many recent snapshots to average for "volume surge" baseline.
ALPHASCANNER_HISTORY_WINDOW=20
